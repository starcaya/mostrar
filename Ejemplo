#include <stdio.h>
#include <stdlib.h>

#define ARCHIVO "productos.dat"

// Estructura del producto
typedef struct {
    int codigo;
    float precio;
    char descripcion[51]; // 50 caracteres + '\0'
} Producto;

/*
---------------------------------------------------------
Función: mostrarProductos
Descripción:
Lee el archivo binario productos.dat y muestra
todos los registros en pantalla.
---------------------------------------------------------
*/
void mostrarProductos(const char *nombreArchivo) {
    FILE *archivo;
    Producto prod;

    // Abrir archivo en modo lectura binaria
    archivo = fopen(nombreArchivo, "rb");

    if (archivo == NULL) {
        printf("Error: No se pudo abrir el archivo %s\n", nombreArchivo);
        return;
    }

    printf("=== LISTADO DE PRODUCTOS ===\n\n");

    // Leer registro por registro
    while (fread(&prod, sizeof(Producto), 1, archivo) == 1) {
        printf("Codigo: %d\n", prod.codigo);
        printf("Precio: %.2f\n", prod.precio);
        printf("Descripcion: %s\n", prod.descripcion);
        printf("-----------------------------\n");
    }

    fclose(archivo);
}

int main() {
    mostrarProductos(ARCHIVO);
    return 0;
}
#include <stdio.h>
#include <stdlib.h>

#define ARCHIVO "productos.dat"

typedef struct {
    int codigo;
    float precio;
    char descripcion[51];
} Producto;

/*
---------------------------------------------------------
Función: aumentarPrecios
Descripción:
Abre el archivo binario en modo lectura/escritura,
lee cada producto, aumenta el precio un 10%
y lo vuelve a guardar en la misma posición.
---------------------------------------------------------
*/
void aumentarPrecios(const char *nombreArchivo) {
    FILE *fp;
    Producto prod;

    // rb+ = lectura y escritura binaria sin borrar contenido
    fp = fopen(nombreArchivo, "rb+");

    if (fp == NULL) {
        printf("Error al abrir el archivo.\n");
        return;
    }

    while (fread(&prod, sizeof(Producto), 1, fp) == 1) {

        // Aumentar 10%
        prod.precio = prod.precio * 1.10;

        /*
        Después de leer, el puntero quedó al final del registro.
        Retrocedemos una posición para sobrescribir ese mismo producto.
        */
        fseek(fp, -sizeof(Producto), SEEK_CUR);

        // Escribir registro modificado
        fwrite(&prod, sizeof(Producto), 1, fp);

        /*
        Algunos compiladores/bibliotecas requieren esto
        al cambiar de escribir -> leer en archivos update (rb+)
        */
        fseek(fp, 0, SEEK_CUR);
    }

    fclose(fp);

    printf("Precios actualizados con 10%% de aumento.\n");
}
